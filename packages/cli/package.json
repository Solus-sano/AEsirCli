{
  "name": "@aesir/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "tsx --test \"test/**/*.test.ts\"",
    "dev": "tsx --env-file ../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aesir/ai": "workspace:*",
    "@aesir/agent-core": "workspace:*"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  }
}
